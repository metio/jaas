jb-test
.bash_history
jaas
.cache
.config

# Go test binaries — `go test -c`, `go test -cpuprofile=…`, etc. drop
# `<package>.test` next to the package. Never source.
*.test
# rapid (pgregory.net/rapid) persists failing-case replay files under a
# package's testdata/rapid/ when a property test fails. They are transient
# debugging aids, not source — keep them out of the tree.
**/testdata/rapid/
.claude/settings.local.json

# Local-only audit/review scratch ledger; not part of the published repo.
open-items.md

# Hugo build output for the docs site (docs/) — generated by `ilo @dev/website`.
docs/public/
docs/resources/
docs/.hugo_build.lock
.vale/

# Generated documentation data — produced by `hack/gen-docs-data.sh` (flaggen
# plus the helm-chart schema flatten). Build artifacts re-derived on every docs
# build, never source.
docs/data/flags.json
docs/data/helm-values.json
docs/data/joi-values.json
docs/data/joi-images.json
